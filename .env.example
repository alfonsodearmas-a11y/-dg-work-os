# =============================================================================
# DG Work OS — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Database (PostgreSQL — Ministry metrics tables)
PG_HOST=
PG_PORT=5432
PG_DATABASE=ministry_dashboard
PG_USER=
PG_PASSWORD=

# Supabase (Documents, tasks, projects, calendar)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Authentication (Google Workspace OAuth via NextAuth v5)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_GOOGLE_DOMAINS=mpua.gov.gy
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Google Calendar (refresh token obtained automatically via OAuth)
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=

# Push Notifications (VAPID keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@mpua.gov.gy

# Cron Jobs (secure cron endpoints)
CRON_SECRET=

# Upload Portal (per-agency access codes for customer service staff)
UPLOAD_ACCESS_CODE_GPL=
UPLOAD_ACCESS_CODE_GWI=
