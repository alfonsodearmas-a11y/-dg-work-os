{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 60,
      "includeFiles": "data/**"
    }
  },
  "crons": [
    {
      "path": "/api/ai/precompute-daily",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/notifications/generate",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/notifications/send-email",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/notifications/digest",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/tm/cron/overdue",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/tm/cron/reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/recurring-tasks",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/psip-nag-weekly",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/action-items/digest",
      "schedule": "5 11 * * *"
    },
    {
      "path": "/api/action-items/drift",
      "schedule": "0 2 * * 0"
    }
  ]
}
